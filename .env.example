# =====================================================================
# mateusnogueira-web — env vars (configure no Vercel > Project > Env)
# =====================================================================

# URL canônica do site (sem trailing slash)
NEXT_PUBLIC_SITE_URL=https://mateusnogueira.com.br

# =====================================================================
# Lead capture
# =====================================================================
# Webhook Make/Integromat que recebe os payloads do POST /api/lead
LEAD_WEBHOOK_URL=

# =====================================================================
# Tracking (P2.10) — todos opcionais e gated por LGPD consent
# =====================================================================
# Meta Pixel — atualmente reutilizamos o Pixel da VAE Hands-On
# (decisão Claude Code Desktop · ecossistema único; separar quando o
# volume justificar Pixel próprio do Dr. Mateus). Trocar para Pixel
# próprio criando tarefa P2.10.1.
NEXT_PUBLIC_META_PIXEL_ID=2158555548323617

# Google Tag Manager — opcional. Se vazio, GTM não é carregado.
# Doutor configura GA4/Ads via GTM quando quiser.
NEXT_PUBLIC_GTM_CONTAINER_ID=
